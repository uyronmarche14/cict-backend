# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/cict-crm
MONGODB_TEST_URI=mongodb://127.0.0.1:27017/cict-crm-test

# JWT Configuration
JWT_SECRET=replace-me-with-a-strong-jwt-secret
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=replace-me-with-a-strong-refresh-secret
JWT_REFRESH_EXPIRE=30d

# Session Configuration
SESSION_SECRET=replace-me-with-a-strong-session-secret

# Security
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000
ALLOW_VERCEL_PREVIEWS=true

# Logging
LOG_LEVEL=info
LOG_TO_FILES=false

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
